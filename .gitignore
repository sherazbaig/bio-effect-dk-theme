# This file contains a list of files and folders to be ignored when
# committing to a git repository.  Ignored files are both Slate project
# specific files as well as commonly ignored files on any project.

# For more information on this .gitignore files, see GitHub's
# documentation: https://help.github.com/articles/ignoring-files/

# Basis #
###################
basis/node_modules
config.yml
deploy.log
dist
documentation
node_modules
npm-debug.log
reports
settings_data.json
storybook
storybook-static
temp
yarn-error.log

# Library #
###################
library
library.log

# Compiled source #
###################
*.class
*.com
*.dll
*.exe
*.o
*.so

# Packages #
############
# it's better to unpack these files and commit the raw source
# git has its own built in compression methods
*.7z
*.dmg
*.gz
*.iso
*.jar
*.rar
*.tar
*.zip

# Logs and databases #
######################
*.log
*.sql
*.sqlite

# OS generated files #
######################
._*
.DS_Store
.DS_Store?
.Spotlight-V100
.Trashes
*.icloud
ehthumbs.db
Thumbs.db

# Custom #
######################
_site
.cache/*
.jekyll-metadata
.ruby-version
*.sass-cache*
/.idea
secrets.json
src/components/async/cnvs-featured-products
