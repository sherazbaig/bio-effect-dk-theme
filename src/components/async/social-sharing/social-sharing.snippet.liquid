{% comment %}
-----------------------------------------------------------------------------
  Snippet: Social sharing

  @param {String} [class] - Additional classes to render.
  @param {Object} section - Section object.
  @param {String} title - Content title.
  @param {String} url - Content URL.
-----------------------------------------------------------------------------
{% endcomment %}
{%- liquid
  unless section.settings.enable_social_sharing
    continue
  endunless

  capture permalink
    echo shop.url | append: url
  endcapture
-%}

<div class="social-sharing {{ class }}">
  <a
    class="social-sharing__icon"
    href="//www.facebook.com/sharer.php?u={{ permalink }}"
    target="_blank"
    title="{{ 'general.social_sharing.facebook' | t }}"
  >
    <span class="visually-hidden">{{ 'general.social_sharing.facebook' | t }}</span>
    {% render 'icon-social' with icon: 'facebook' %}
  </a>

  <a
    class="social-sharing__icon"
    href="//pinterest.com/pin/create/button/?url={{ permalink }}&amp;description={{ title | escape }}"
    target="_blank"
    title="{{ 'general.social_sharing.pinterest' | t }}"
  >
    <span class="visually-hidden">{{ 'general.social_sharing.pinterest' | t }}</span>
    {% render 'icon-social' with icon: 'pinterest' %}
  </a>

  <a
    class="social-sharing__icon"
    href="//twitter.com/share?url={{ permalink }}"
    target="_blank"
    title="{{ 'general.social_sharing.twitter' | t }}"
  >
    <span class="visually-hidden">{{ 'general.social_sharing.twitter' | t }}</span>
    {% render 'icon-social' with icon: 'twitter' %}
  </a>

  <a
    class="social-sharing__icon"
    href="whatsapp://send?text={{ permalink }}"
    target="_blank"
    title="{{ 'general.social_sharing.whatsapp' | t }}"
    data-action="share/whatsapp/share"
  >
    <span class="visually-hidden">{{ 'general.social_sharing.whatsapp' | t }}</span>
    {% render 'icon-social' with icon: 'whatsapp' %}
  </a>
</div>
