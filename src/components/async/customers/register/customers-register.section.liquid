{% comment %}
------------------------------------------------------------------------------
  Section: Customers register (customers-register)
  - Static section.
------------------------------------------------------------------------------
{% endcomment %}
{{ 'component.customers-register.css' | asset_url | stylesheet_tag }}

<section
   class="customers critical-customers-clear"
  aria-labelledby="template-title"
  data-component-handle="customers-register"
>
  <div
    class="
      customers-register
      customers__onboarding
      {% if settings.customers_onboarding_image != blank %}
        customers__onboarding--has-image
      {% endif %}
      critical-component-clear
      liquid
    "
  >
    {% render 'customers-onboarding-image'%}

    <div class="customers__onboarding-content grid container">
      <div class="customers__onboarding-forms col xs-span l4-9">
        {% render 'register-form' %}
      </div>
    </div>
  </div>
</section>

{% schema 'customers-register' %}
