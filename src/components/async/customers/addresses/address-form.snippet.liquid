      </div>

      <div
        class="form-group__field is-hidden"
        js-addresses="provinceContainer"
      >
        {%- liquid
          assign error_type = 'province'
          assign error_namespace = error_namespace_string | replace: '#', error_type
        -%}

        <select
          id="province-{{ form_id }}"
          {% if form.errors contains error_type %}
            class="has-error"
          {% endif %}
          name="address[province]"
