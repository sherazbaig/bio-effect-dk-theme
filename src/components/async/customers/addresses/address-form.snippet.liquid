        {% render 'form-errors' with
          class: 'form-group__note',
          form: form,
          namespace: namespace,
          type: error_type,
        %}
      </div>

      <div class="form-group__field form-group__field-default">
        {% render 'checkbox-input' with
          checked: set_as_default_checked,
          disabled: set_as_default_disabled,
          id: set_as_default_id,
          input: form.set_as_default_checkbox,
          label: set_as_default_string,
        %}
      </div>
    </div>

    <div class="form-group__footer mt-xl">
      {% render 'btn'
        attributes: 'js-addresses="cancel"',
        class: 'customers-addresses__cancel',
        icon: cancel_icon,
        label: cancel_string_cta,
        modifiers: 'secondary center',
        type: 'button',
      %}

      {% render 'btn' with
        class: 'customers-addresses__submit',
        label: confirm_string_cta,
        type: 'submit',
        modifiers: 'primary center'
      %}
    </div>
  {% endform %}
</div>
