{% comment %}
----------------------------------------------------------------------------
  Snippet: Address form
  - Used to output all address fields in the addresses template.

  @param {Object} address - Liquid form address.
  @param {Boolean} [default_address] - Is the address the default?
  @param {String} form_id - Form ID.
----------------------------------------------------------------------------
{% endcomment %}
{%- liquid
  assign edit_address = true
  assign cancel_string = 'customers.addresses.#.cancel' | replace: '#', 'edit'
  assign confirm_string = 'customers.addresses.#.confirm' | replace: '#', 'edit'
  assign set_as_default_string = 'customers.addresses.#.set_as_default' | replace: '#', 'edit'
  assign text_setting = 'customers.addresses.#.text_html' | replace: '#', 'edit'
  assign title_setting = 'customers.addresses.#.title' | replace: '#', 'edit'

  if form_id == 'new'
    assign edit_address = false
    assign cancel_string = cancel_string | replace: 'edit', 'new'
    assign confirm_string = confirm_string | replace: 'edit', 'new'
    assign set_as_default_string = set_as_default_string | replace: 'edit', 'new'
    assign text_setting = text_setting | replace: 'edit', 'new'
    assign title_setting = title_setting | replace: 'edit', 'new'
  endif

  # Strings
  assign confirm_string_cta = confirm_string | t
  assign cancel_string_cta = cancel_string | t
  assign error_namespace_string = 'address-#-errors-form' | replace: 'form', form_id
  assign set_as_default_string = set_as_default_string | t
  assign text_string = text_setting | t

  # Set as default
  assign set_as_default_id = 'address_default_address_' | append: form_id

  if default_address
    assign set_as_default_checked = true
    assign set_as_default_disabled = true
  endif

  # Cancel icon
  capture cancel_icon
    render 'icon-directional-navigation' with icon: 'arrow', direction: 'left'
  endcapture
-%}

<div
  class="customers-addresses__form is-hidden"
  data-form-id="{{ form_id }}"
  js-addresses="forms"
>
  {% # Used to format address when shown in default/delete modals %}
  <div
    class="customers-addresses__form-address"
    js-addresses="address"
  >
    {% render 'address-block'
      address: address,
      address_only: true,
    %}
  </div>

  {% render 'form-errors' with
    class: 'is-hidden',
    form: form,
    form_id: form_id,
  %}

  {% form 'customer_address', address, js-addresses: 'form', return_to: routes.account_url %}
    <div class="form-group">
      <div class="form-group__field">
        {%- liquid
          assign error_type = 'first_name'
          assign error_namespace = error_namespace_string | replace: '#', error_type
        -%}

        <input
          id="first-name-{{ form_id }}"
          {% if form.errors contains error_type %}
            class="has-error"
          {% endif %}
          autocapitalize="words"
          autocomplete="given-name"
          autocorrect="off"
          placeholder="{{ 'customers.fields.first_name.placeholder' | t }}"
          name="address[first_name]"
          required
          type="text"
          {% if edit_address %}
            value="{{ form.first_name }}"
          {% endif %}
          {% if form.errors contains error_type %}
            aria-describedby="{{ error_namespace }}-errors"
            aria-invalid="true"
          {% endif %}
        >

        <label
          class="form-group__label text-tags"
          for="first-name-{{ form_id }}"
        >
          {{ 'customers.fields.first_name.label' | t }}

          <abbr title="{{ 'customers.fields.required.label' | t }}">
            {{ 'customers.fields.required.symbol' | t }}
          </abbr>
        </label>

        {% render 'form-errors' with
          class: 'form-group__note',
          form: form,
          namespace: namespace,
          type: error_type,
        %}
      </div>

      <div class="form-group__field">
        {%- liquid
          assign error_type = 'last_name'
          assign error_namespace = error_namespace_string | replace: '#', error_type
        -%}

        <input
          id="last-name-{{ form_id }}"
          {% if form.errors contains error_type %}
            class="has-error"
          {% endif %}
          autocapitalize="words"
          autocomplete="family-name"
          autocorrect="off"
          name="address[last_name]"
          placeholder="{{ 'customers.fields.last_name.placeholder' | t }}"
          required
          type="text"
          {% if edit_address %}
            value="{{ form.last_name }}"
          {% endif %}
          {% if form.errors contains error_type %}
            aria-describedby="{{ error_namespace }}-errors"
            aria-invalid="true"
          {% endif %}
        >

        <label
          class="form-group__label text-tags"
          for="last-name-{{ form_id }}"
        >
          {{ 'customers.fields.last_name.label' | t }}

          <abbr title="{{ 'customers.fields.required.label' | t }}">
            {{ 'customers.fields.required.symbol' | t }}
          </abbr>
        </label>

        {% render 'form-errors' with
          class: 'form-group__note',
          form: form,
          namespace: namespace,
          type: error_type,
        %}
      </div>

      <div class="form-group__field">
        {%- liquid
          assign error_type = 'company'
          assign error_namespace = error_namespace_string | replace: '#', error_type
        -%}

        <input
          id="company-{{ form_id }}"
          {% if form.errors contains error_type %}
            class="has-error"
          {% endif %}
          autocomplete="organization"
          autocorrect="off"
          name="address[company]"
          placeholder="{{ 'customers.fields.company.placeholder' | t }}"
          type="text"
          {% if edit_address %}
            value="{{ form.company }}"
          {% endif %}
          {% if form.errors contains error_type %}
            aria-describedby="{{ error_namespace }}-errors"
            aria-invalid="true"
          {% endif %}
        >

        <label
          class="form-group__label text-tags"
          for="company-{{ form_id }}"
        >
          {{ 'customers.fields.company.label' | t }}
        </label>

        {% render 'form-errors' with
          class: 'form-group__note',
          form: form,
          namespace: namespace,
          type: error_type,
        %}
      </div>

  <div class="form-group__field">
        {%- liquid
          assign error_type = 'phone'
          assign error_namespace = error_namespace_string | replace: '#', error_type
        -%}

        <input
          id="phone-{{ form_id }}"
          {% if form.errors contains error_type %}
            class="has-error"
          {% endif %}
          autocomplete="tel"
          name="address[phone]"
          required
          pattern="[0-9\-\+\s]*"
          placeholder="{{ 'customers.fields.phone.placeholder' | t }}"
          type="tel"
          {% if edit_address %}
            value="{{ form.phone }}"
          {% endif %}
          {% if form.errors contains error_type %}
            aria-describedby="{{ error_namespace }}-errors"
            aria-invalid="true"
          {% endif %}
        >

        <label
          class="form-group__label text-tags"
          for="phone-{{ form_id }}"
        >
          {{ 'customers.fields.phone.label' | t }}

          <abbr title="{{ 'customers.fields.required.label' | t }}">
