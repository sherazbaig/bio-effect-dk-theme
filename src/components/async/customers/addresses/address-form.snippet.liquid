      <div class="form-group__field">
        {%- liquid
          assign error_type = 'country'
          assign error_namespace = error_namespace_string | replace: '#', error_type
        -%}

        <select
          id="country-{{ form_id }}"
          {% if form.errors contains error_type %}
            class="has-error"
          {% endif %}
          autocomplete="country-name"
          name="address[country]"
          required
          {% if form.errors contains error_type %}
            aria-describedby="address-errors-{{ form.id }}"
            aria-invalid="true"
          {% endif %}
          data-default="{{ form.country }}"
          data-form-id="{{ form_id }}"
          js-addresses="country"
        >
          {{ country_option_tags }}
        </select>

        <label
          class="form-group__label text-tags"
          for="country-{{ form_id }}"
        >
          {{ 'customers.fields.country.label' | t }}

          <abbr title="{{ 'customers.fields.required.label' | t }}">
