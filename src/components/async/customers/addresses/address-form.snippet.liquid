      </div>

      <div class="form-group__field">
        {%- liquid
          assign error_type = 'zip'
          assign error_namespace = error_namespace_string | replace: '#', error_type
        -%}

        <input
          id="zip-{{ form_id }}"
          {% if form.errors contains error_type %}
            class="has-error"
          {% endif %}
          autocapitalize="characters"
          autocomplete="postal-code"
          name="address[zip]"
          placeholder="{{ 'customers.fields.zip.placeholder' | t }}"
          required
          type="text"
          {% if edit_address %}
            value="{{ form.zip }}"
          {% endif %}
          {% if form.errors contains error_type %}
