{% comment %}
-----------------------------------------------------------------------------
  Section: Promo banner (promo-banner)
  - Component is only loaded if the section has blocks, otherwise the early
    continue prevents loading it.
-----------------------------------------------------------------------------
{% endcomment %}
{%- liquid
  if section.blocks.size < 1
    continue
  endif

  assign up_sell_product = section.settings.up_sell_product
-%}

<section
  aria-labelledby="section-title-{{ section.id }}"
  data-sign-post-location="head"
  data-sign-post-priority="1"
  {% render 'header-states' with section: section %}
>
  <promo-banner
    v-show="getComponentActive('promo-banner')"
    v-cloak
    :autoscroll="{
      enable: {{ section.settings.enable_autoscroll | json | escape }},
      timing: {{ section.settings.autoscroll_timing | json | escape }}
    }"
    :blocks="[
      {%- for block in section.blocks -%}
        {
          title: {{ block.settings.title | json | escape }},
        }{%- unless forloop.last -%},{%- endunless -%}
      {%- endfor -%}
    ]"
    :desktop-message="{{ section.settings.desktop_message | json | escape }}"
    :display-store-selector="{{ section.settings.display_store_selector | json | escape }}"
    :display-account="{{ section.settings.display_account | json | escape }}"
    :liquid="{
      sectionId: {{ section.id | json | escape }},
      {% if
        up_sell_product != blank and
        up_sell_product.metafields.seo.hidden != 1
      %}
        upSellProduct: {% render 'format-product' with product: up_sell_product %}
      {% endif %}
    }"
  ></promo-banner>

  {% comment %}
  ----------------------------------------------------------------------------
    Loading state.
  ----------------------------------------------------------------------------
  {% endcomment %}
  <div v-if="!getComponentActive('promo-banner')">
    {%- liquid
      assign block_count = section.blocks.size | at_least: 1
      assign marquee_duration = section.settings.autoscroll_timing | times: block_count
    -%}
    <div
      class="promo-banner is-loading critical-component-hide liquid"
      style="--marquee-duration: {{ marquee_duration }}s;"
    >
      <div class="promo-banner__container container">
        <div class="promo-banner__marquee-wrapper">
          <ul class="promo-banner__list{% unless section.settings.enable_autoscroll %} promo-banner__list--static{% endunless %}">
            {% comment %} Render blocks twice for seamless marquee loop {% endcomment %}
            {% for i in (1..2) %}
              {% for block in section.blocks %}
                <li
                  class="promo-banner__list-item text-other-label-s"
                  {% if forloop.parentloop.index == 1 %}{{ block.shopify_attributes }}{% endif %}
                  {% if forloop.parentloop.index == 2 %}aria-hidden="true"{% endif %}
                >
                  <span>
                    {{ block.settings.title | replace: '<a', '<a class="text-other-label-s"' | replace: '<strong', '<strong class="text-other-label-s"' }}
                  </span>
                </li>
              {% endfor %}
            {% endfor %}
          </ul>
        </div>

        {% if section.settings.display_store_selector %}
          <div class="promo-banner__country-select">
            {% render 'country-select' %}
          </div>
        {% endif %}

        <div class="promo-banner__desktop-icons">
          {% if section.settings.display_account %}
            <div class="promo-banner__account">
              {% render 'icon-general' with icon: 'account' %}

              <span class="promo-banner__account-label text-p-xs-bold">
                {{ 'general.site_header.account' | t }}
              </span>
            </div>
          {% endif %}
        </div>
      </div>
    </div>
  </div>
</section>

{% schema 'promo-banner' %}
