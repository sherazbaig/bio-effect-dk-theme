{% comment %}
-----------------------------------------------------------------------------
  Snippet / Schema: Breadcrumbs
  - Breadcrumbs navigation schema data.
-----------------------------------------------------------------------------
{% endcomment %}
{%- liquid
  assign excluded = 'cart,index,list-collections' | split: ','

  if excluded contains request.page_type
    continue
  endif

  assign two_id = canonical_url
  assign two_name = page_title

  case request.page_type
    when 'article'
      assign two_id = blog.url | prepend: shop.url
      assign two_name = blog.title

      assign three_id = article.url | prepend: shop.url
      assign three_name = article.title

    when 'product'
      if collection.title != blank
        assign two_id = collection.url | prepend: shop.url
        assign two_name = collection.title

        assign three_id = collection.url | append: product.url | prepend: shop.url
        assign three_name = product.title
      endif
  endcase
-%}

<script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement":
    [
      {
        "@type": "ListItem",
        "position": 1,
        "item":
        {
          "@id": {{ localization.language.root_url | prepend: request.origin | json }},
          "name": {{ 'general.breadcrumbs.home' | t | json }}
        }
      },
      {
        "@type": "ListItem",
        "position": 2,
        "item": {
          "@id": {{ two_id | json }},
          "name": {{ two_name | json }}
        }
      }
      {% if three_id != blank %},
        {
          "@type": "ListItem",
          "position": 3,
          "item": {
            "@id": {{ three_id | json }},
            "name": {{ three_name | json }}
          }
        }
      {% endif %}
    ]
  }
</script>
