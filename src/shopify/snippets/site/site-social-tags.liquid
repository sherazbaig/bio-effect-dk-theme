{% comment %}
-----------------------------------------------------------------------------
  Snippet / Site: Social tags
  - OpenGraph tags used by social media services to generate preview content.
  - Update Online Store > Preferences with default sharing image.
  - Based on Dawn: https://github.com/Shopify/dawn/blob/main/snippets/meta-tags.liquid
-----------------------------------------------------------------------------
{% endcomment %}
{%- liquid
  assign og_description = page_description | default: shop.description | default: shop.name
  assign og_title = page_title | default: shop.name
  assign og_type = 'website'
  assign og_url = canonical_url | default: request.origin

  case request.page_type
    when 'article'
      assign og_type = 'article'
    when 'collection'
      assign og_type = 'product.group'
    when 'password'
      assign og_url = request.origin
    when 'product'
      assign og_type = 'product'
  endcase
-%}

{% comment %}
-----------------------------------------------------------------------------
  Meta tags.
  - https://developers.facebook.com/docs/sharing/webmasters#basic
-----------------------------------------------------------------------------
{% endcomment %}
<meta property="og:description" content="{{ og_description | escape }}">
<meta property="og:locale" content="{{ localization.language.iso_code | replace: '-', '_' }}">
<meta property="og:site_name" content="{{ shop.name }}">
<meta property="og:title" content="{{ og_title | escape }}">
<meta property="og:type" content="{{ og_type }}">
<meta property="og:url" content="{{ og_url }}">

{% comment %}
-----------------------------------------------------------------------------
  Image tags.
  - https://developers.facebook.com/docs/sharing/webmasters#images
-----------------------------------------------------------------------------
{% endcomment %}
{%- if page_image -%}
  <meta property="og:image" content="http:{{ page_image | image_url: width: page_image.width }}">
  <meta property="og:image:alt" content="{{ page_image.alt }}">
  <meta property="og:image:height" content="{{ page_image.height }}">
  <meta property="og:image:secure_url" content="https:{{ page_image | image_url: width: page_image.width }}">
  <meta property="og:image:width" content="{{ page_image.width }}">
{%- endif -%}

{% comment %}
-----------------------------------------------------------------------------
  Product-specific tags.
  - https://developers.facebook.com/docs/payments/product/
-----------------------------------------------------------------------------
{% endcomment %}
{%- if request.page_type == 'product' -%}
  <meta property="product:price:amount" content="{{ product.price | money_without_currency | strip_html }}" >
  <meta property="product:price:currency" content="{{ cart.currency.iso_code }}">
{%- endif -%}

{% comment %}
-----------------------------------------------------------------------------
  Twitter tags.
  - https://developer.twitter.com/en/docs/twitter-for-websites/cards/overview/markup
-----------------------------------------------------------------------------
{% endcomment %}
{%- if settings.social_twitter_link != blank -%}
  <meta name="twitter:site" content="{{ settings.social_twitter_link | split: 'twitter.com/' | last | prepend: '@' }}" >
{%- endif -%}

{%- if page_image -%}
  <meta name="twitter:image" content="https:{{ page_image | image_url: width: page_image.width }}">
{%- endif -%}

<meta name="twitter:card" content="summary_large_image">
<meta name="twitter:description" content="{{ og_description | escape }}">
<meta name="twitter:title" content="{{ og_title | escape }}">
