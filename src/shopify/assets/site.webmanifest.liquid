{
  "name": {{ shop.name | json }},
  "short_name": "",
  {% if settings.favicon != blank %}
    "icons": [
      {
        "src": {{ settings.favicon | image_url: width: 196, height: 196, crop: 'center', format: 'jpg' | json }},
        "sizes": "192x192",
        "type": "image/jpg"
      },
      {
        "src": {{ settings.favicon | image_url: width: 512, height: 512, crop: 'center', format: 'jpg' | json }},
        "sizes": "512x512",
        "type": "image/jpg"
      }
    ],
  {% endif %}
  {% if settings.site_colour != blank %}
    "theme_color": {{ settings.site_colour | json }},
  {% endif %}
  {% if settings.site_background_colour != blank %}
    "background_color": {{ settings.site_background_colour | json }}
  {% endif %}
}
