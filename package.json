    "eslint": "8.41.0",
    "eslint-import-resolver-webpack": "0.13.2",
    "eslint-plugin-storybook": "0.6.12",
    "graphql-config": "5.0.1",
    "husky": "8.0.3",
    "lint-staged": "13.2.2",
