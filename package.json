    "stylelint": "15.6.2"
  },
  "peerDependencies": {
    "graphql": "16.6.0",
    "graphql-tag": "2.12.6"
  },
  "dependencies": {
    "@bugsnag/js": "7.20.2",
    "@bugsnag/plugin-vue": "7.19.0",
    "@shopify/theme-cart": "4.1.1",
    "@splidejs/vue-splide": "0.6.12",
    "@we-make-websites/click-outside": "file:./local_modules/@we-make-websites/click-outside",
    "@we-make-websites/theme-currency": "file:./local_modules/@we-make-websites/theme-currency",
    "body-scroll-lock": "3.1.5",
    "sass-mq": "6.0.0",
    "vue": "3.3.4",
    "vuex": "4.1.0",
    "vuex-persistedstate": "4.1.0"
  },
  "engineStrict": true,
  "engines": {
    "node": "^16.17.0"
  },
  "imports": {
    "#fragments/*": "./src/schemas/fragments/*.js"
  },
  "lint-staged": {
    "*.scss": "stylelint",
    "*.{js,vue}": "eslint"
  },
  "scripts": {
    "build": "basis-build",
    "component": "component-create",
    "copy": "basis-copy",
    "deploy": "basis-build && basis-deploy",
    "design": "design-convert",
    "docs": "basis-schema-docs",
    "download": "basis-download",
    "helpme": "basis-help",
    "hot": "basis-watch --hot",
    "locales": "basis-locales",
    "postinstall": "node ./canvas/postinstall.js",
    "start": "yarn run watch",
    "storybook-build": "storybook-build",
    "storybook": "storybook-watch",
    "templates": "basis-templates",
    "watch": "basis-watch"
